#!/bin/sh
# Shows stats of a git repo.
#
# usage:
#   git-stats [<path>]        repo overview
#   git-stats loc [<path>]    graph lines of code over commits

# shellcheck disable=2059

# Utils
# text formatting
_reset="\e[0;0m"
_red="\e[1;31m"
_green="\e[1;32m"
_yellow="\e[1;33m"
_blue="\e[1;34m"
_strong="\e[1;39m"

# character gnuplot's dumb terminal draws the data line with (it hardcodes '*')
_plot_char="•"

# print a labelled stat row
_row() {
  printf "  %-14s ${_strong}%s${_reset}\n" "$1" "$2"
}

# count lines of code at a revision; -I skips binaries, '^' matches every line
_loc_at() {
  git grep -I -c '^' "$1" -- 2>/dev/null | awk -F: '{s+=$NF} END{print s+0}'
}

# graph lines of code over the history of HEAD (X: commits, Y: lines)
_graph_loc() {
  _n=$(git rev-list --count HEAD)

  # plot box sized to the terminal, with sane fallbacks when there is no tty
  _cols=$(tput cols 2>/dev/null); [ -n "$_cols" ] || _cols=80
  _rows=$(tput lines 2>/dev/null); [ -n "$_rows" ] || _rows=24
  _w=$(( _cols - 12 )); [ "$_w" -lt 20 ] && _w=20
  _h=$(( _rows - 6 ));  [ "$_h" -lt 10 ] && _h=10
  [ "$_h" -gt 22 ] && _h=22

  # sample at most one commit per column, oldest to newest, always keeping HEAD
  _p="$_w"; [ "$_n" -lt "$_p" ] && _p="$_n"

  _tmp=$(mktemp) || return 1
  git rev-list --reverse HEAD | awk -v n="$_n" -v p="$_p" '
    BEGIN { step = int((n + p - 1) / p); if (step < 1) step = 1 }
    (NR - 1) % step == 0 || NR == n { print NR, $0 }
  ' | while read -r _ord _hash; do
        printf '%s\t%s\n' "$_ord" "$(_loc_at "$_hash")"
      done > "$_tmp"

  printf "${_strong}%s${_reset} — lines of code over %s commits\n\n" "$_name" "$_n"

  if command -v gnuplot >/dev/null 2>&1; then
    gnuplot -e "
      set terminal dumb size $(( _cols - 2 )),$(( _h + 4 ));
      unset key; set tics nomirror;
      set xlabel 'commit'; set ylabel 'lines';
      plot '$_tmp' using 1:2 with lines
    " 2>/dev/null | sed "s/[*]/$_plot_char/g"
  else
    # pure-awk column chart fallback
    awk -v H="$_h" '
      { ord[NR]=$1; v[NR]=$2; if (NR==1 || $2>mx) mx=$2; if (NR==1 || $2<mn) mn=$2; m=NR }
      END {
        if (m == 0) exit
        rng = mx - mn; if (rng == 0) rng = 1
        for (i = 1; i <= m; i++) ht[i] = int((v[i] - mn) / rng * (H - 1)) + 1
        for (r = H; r >= 1; r--) {
          lab = (r == H) ? mx : ((r == 1) ? mn : "")
          printf "%8s │", lab
          for (i = 1; i <= m; i++) printf "%s", (ht[i] >= r) ? "█" : " "
          printf "\n"
        }
        printf "%8s └", ""
        for (i = 1; i <= m; i++) printf "─"
        printf "\n         commit 1 → %d\n", ord[m]
      }' "$_tmp"
  fi

  rm -f "$_tmp"
}

# Main
# pull off an optional subcommand
_sub=""
case "$1" in
  loc) _sub=loc; shift ;;
esac

# cd to repo if valid path is inputted
if [ -d "$1/.git" ]; then
  cd "$1" || exit
fi

# bail if not inside a work tree
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  printf "${_red}Not a Git repository.${_reset}\n"
  exit 1
fi

_root=$(git rev-parse --show-toplevel)
_name=$(basename "$_root")
_branch=$(git symbolic-ref --short -q HEAD || echo "(detached)")

# is there at least one commit?
_has_head=true
git rev-parse --verify -q HEAD >/dev/null || _has_head=false

# loc subcommand: draw the graph and stop
if [ "$_sub" = loc ]; then
  if [ "$_has_head" = false ]; then
    printf "${_yellow}No commits yet.${_reset}\n"
    exit 0
  fi
  _graph_loc
  exit 0
fi

# --- overview ---
printf "${_strong}%s${_reset} on ${_blue}%s${_reset}\n\n" "$_name" "$_branch"

# bail early on an empty repo (no commits yet)
if [ "$_has_head" = false ]; then
  printf "${_yellow}No commits yet.${_reset}\n"
  exit 0
fi

# History
# Earliest root commit is the first commit; sort handles repos with many roots.
_first_epoch=$(git log --max-parents=0 --format='%at' | sort -n | head -1)
_first_date=$(date -d "@$_first_epoch" '+%Y-%m-%d')
_age_days=$(( ( $(date +%s) - _first_epoch ) / 86400 ))

printf "${_blue}History${_reset}\n"
_row "Commits" "$(git rev-list --count HEAD)"
_row "Authors" "$(git log --format='%aN' | sort -u | wc -l)"
_row "First commit" "$_first_date"
_row "Last commit" "$(git log -1 --format='%ad' --date=short) ($(git log -1 --format='%ad' --date=relative))"
_row "Age" "$_age_days days"
echo

# Content
printf "${_blue}Content${_reset}\n"
_row "Tracked files" "$(git ls-files | wc -l)"
_row "Lines" "$(_loc_at HEAD)"
_row "On disk" "$(du -sb "$_root" | cut -f1 | numfmt --to=iec)"
_row ".git history" "$(du -sb "$_root/.git" | cut -f1 | numfmt --to=iec)"
echo

# Refs
printf "${_blue}Refs${_reset}\n"
_row "Branches" "$(git for-each-ref --format='%(refname)' refs/heads | wc -l)"
_row "Tags" "$(git tag | wc -l)"
_row "Remotes" "$(git remote | wc -l)"
echo

# Top authors by commit count
printf "${_blue}Top authors${_reset}\n"
git shortlog -sn HEAD | head -5 | while read -r _count _author; do
  printf "  ${_green}%5s${_reset}  %s\n" "$_count" "$_author"
done
