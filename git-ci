#!/bin/sh
# Pull and push on a Git repository but only if it makes sense.
# This does a job similar to git sync but smarter and more suitable for automated envs.

# usage: git-ci <path-to-parent-dir> (optional)

# Logging 
# shellcheck disable=2059

if [ "$TERM" = "dumb" ]; then
  # systemd
  _log_emerg="<0>%s\n" # red
  _log_alert="<1>%s\n"
  _log_crit="<2>%s\n"
  _log_error="<3>%s\n"
  _log_warning="<4>%s\n" # yellow
  _log_notice="<5>%s\n" # white
  _log_info="<6>%s\n"
  _log_debug="<7>%s\n" # muted 

else
  # interactive shell
  _fmt_clear="\e[0;0m"
  _fmt_bold="\e[1;0m"
  _fmt_red="\e[1;31m"
  _fmt_yellow="\e[1;33m"
  _fmt_blue="\e[1;34m"
  _fmt_gray="\e[1;30m"
  _log_emerg="${_fmt_red}EMERGENCY: %s${_fmt_clear}\n\n"
  _log_alert="${_fmt_red}ALERT: %s${_fmt_clear}\n\n"
  _log_crit="${_fmt_red}CRITICAL: %s${_fmt_clear}\n\n"
  _log_error="${_fmt_red}ERROR: %s${_fmt_clear}\n\n"
  _log_warning="${_fmt_yellow}WARNING: %s${_fmt_clear}\n\n"
  _log_notice="${_fmt_bold}NOTICE: %s${_fmt_clear}\n\n"
  _log_info="${_fmt_clear}INFO: %s\n${_fmt_clear}\n\n"
  _log_debug="${_fmt_gray}DEBUG: %s${_fmt_clear}\n\n"
fi

# Main
# change dir to inputted path if valid
if [ -d "$1" ]; then
  cd "$1" || exit 1
fi

# Check before acting
_check() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf "$_log_error" "Not a Git repository."
    return 1
  fi

  if [ -z "$(git remote)" ]; then
    printf "$_log_error" "Repository has no remotes."
    return 1
  fi

  # Refresh the index so stat-dirty entries don't false-positive, then bail on
  # ANY staged/unstaged/untracked change (--porcelain already honors .gitignore).
  git update-index -q --refresh
  if [ -n "$(git status --porcelain)" ]; then
    printf "$_log_warning" "Repository is dirty. Skipping."
    return 1
  fi
}

# Pull changes
_pull() {
  # NOTE: Fetching all is important to fetch upstream commits on forks.
  # --all preserves shallowness on shallow clones, so no special-casing needed.
  git fetch --all --prune || return 1

  # Nothing to integrate without an upstream for the current branch.
  if ! git rev-parse --symbolic-full-name '@{upstream}' >/dev/null 2>&1; then
    printf "$_log_info" "No upstream configured. Skipping integration."
    return 0
  fi

  # Fast-forward only: refuse to auto-rebase/merge divergent history unattended.
  # If two machines both committed before syncing, that's a conflict for a human.
  if ! git merge --ff-only '@{upstream}'; then
    printf "$_log_warning" "Local history diverged from upstream. Manual resolution needed."
    return 1
  fi
}

# Push changes
_push() {
  _branch=$(git symbolic-ref --short -q HEAD) || {
    printf "$_log_warning" "Detached HEAD. Skipping push."
    return 0
  }

  case "$_branch" in
    main|master) ;;
    *)
      printf "$_log_warning" "Branch '$_branch' is not main/master. Skipping push."
      return 0 ;;
  esac

  # NOTE: Authentication is completely server-side and Git can't know if user
  # is allowed to push. A workaround to prevent pushes is to set 'pushurl' to
  # an invalid value.

  if git remote | grep -q gerrit; then
    printf "$_log_info" "Gerrit repository. Skip push."
    return 0
  fi

  if ! git rev-parse --symbolic-full-name '@{upstream}' >/dev/null 2>&1; then
    printf "$_log_info" "No upstream configured. Skipping push."
    return 0
  fi

  if [ "$(git rev-list --count '@{upstream}'..HEAD)" -eq 0 ]; then
    printf "$_log_info" "No commits to push."
    return 0
  fi

  git push
}

_check || exit 1
_pull  || exit 1
_push
